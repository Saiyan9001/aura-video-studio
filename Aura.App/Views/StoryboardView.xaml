<Page
    x:Class="Aura.App.Views.StoryboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Aura.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
            <TextBlock 
                Text="Storyboard Editor" 
                Style="{ThemeResource TitleTextBlockStyle}"/>
            <TextBlock 
                Text="Timeline-based editing with tracks, transitions, and effects"
                Style="{ThemeResource BodyTextBlockStyle}"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>
        
        <!-- Timeline Area with Inspector Panel -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*" MinWidth="300"/>
            </Grid.ColumnDefinitions>
            
            <!-- Timeline Area (Placeholder) -->
            <Grid Grid.Column="0" 
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                  BorderThickness="2" 
                  CornerRadius="8"
                  Background="{ThemeResource LayerFillColorDefaultBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Margin="40">
                    <FontIcon Glyph="&#xE70F;" FontSize="64" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock 
                        Text="Advanced Timeline Editor" 
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center"/>
                    <TextBlock 
                        Text="Professional video editing with precision timeline controls"
                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                        TextAlignment="Center"
                        MaxWidth="500"
                        TextWrapping="Wrap"/>
                    <StackPanel Spacing="8" MaxWidth="500">
                        <TextBlock Text="Features:" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <Grid ColumnSpacing="20" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8B7;" FontSize="12"/>
                                <TextBlock Text="Multiple video tracks"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8D6;" FontSize="12"/>
                                <TextBlock Text="Audio mixing"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8B5;" FontSize="12"/>
                                <TextBlock Text="Transitions"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE7C3;" FontSize="12"/>
                                <TextBlock Text="Timeline markers"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8EF;" FontSize="12"/>
                                <TextBlock Text="Visual effects"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8CB;" FontSize="12"/>
                                <TextBlock Text="Keyframe animation"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <TextBlock 
                        Text="Coming soon: Full implementation"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                        FontStyle="Italic"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
            
            <!-- Scene Inspector Panel -->
            <Grid Grid.Column="1" 
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                  BorderThickness="2" 
                  CornerRadius="8"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  Padding="16">
                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <TextBlock 
                            Text="Scene Inspector" 
                            Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        
                        <TextBlock 
                            Text="Per-Scene Visual Overrides"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Margin="0,8,0,0"/>
                        
                        <ComboBox 
                            Header="Visual Provider"
                            HorizontalAlignment="Stretch"
                            SelectedIndex="0"
                            ToolTipService.ToolTip="Override visual provider for this scene">
                            <ComboBoxItem Content="Use Global Setting"/>
                            <ComboBoxItem Content="Stock Images"/>
                            <ComboBoxItem Content="Local SD"/>
                            <ComboBoxItem Content="Solid Color"/>
                        </ComboBox>
                        
                        <TextBox 
                            Header="Custom Keywords"
                            PlaceholderText="e.g., sunset, mountains, nature"
                            ToolTipService.ToolTip="Override search/generation keywords for this scene"/>
                        
                        <ComboBox 
                            Header="Style Override"
                            HorizontalAlignment="Stretch"
                            SelectedIndex="0"
                            ToolTipService.ToolTip="Override visual style for this scene">
                            <ComboBoxItem Content="Use Global Setting"/>
                            <ComboBoxItem Content="Cinematic"/>
                            <ComboBoxItem Content="Photographic"/>
                            <ComboBoxItem Content="Artistic"/>
                            <ComboBoxItem Content="Abstract"/>
                        </ComboBox>
                        
                        <TextBlock 
                            Text="Stable Diffusion Overrides"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Margin="0,8,0,0"/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock 
                                Text="Steps: 20"
                                Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <Slider 
                                Minimum="5" 
                                Maximum="50" 
                                Value="20"
                                StepFrequency="5"
                                ToolTipService.ToolTip="Override SD steps for this scene"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="8">
                            <TextBlock 
                                Text="CFG Scale: 7.0"
                                Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <Slider 
                                Minimum="1" 
                                Maximum="20" 
                                Value="7"
                                StepFrequency="0.5"
                                ToolTipService.ToolTip="Override CFG scale for this scene"/>
                        </StackPanel>
                        
                        <TextBox 
                            Header="Seed Override"
                            PlaceholderText="-1 for random"
                            Text="-1"
                            ToolTipService.ToolTip="Override seed for this scene"/>
                        
                        <Button 
                            Content="Apply Overrides"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"/>
                        
                        <Button 
                            Content="Clear Overrides"
                            HorizontalAlignment="Stretch"
                            ToolTipService.ToolTip="Remove all scene-specific overrides"/>
                        
                        <InfoBar
                            Title="Scene Overrides"
                            Message="Scene-specific settings override global visual configuration. Leave as 'Use Global Setting' to inherit."
                            Severity="Informational"
                            IsClosable="False"
                            Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
        
        <!-- Toolbar -->
        <CommandBar Grid.Row="2" DefaultLabelPosition="Right" Margin="0,16,0,0">
            <AppBarButton Icon="Play" Label="Play" ToolTipService.ToolTip="Play/Pause (Space)"/>
            <AppBarButton Icon="Stop" Label="Stop" ToolTipService.ToolTip="Stop playback"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Cut" Label="Split" ToolTipService.ToolTip="Split clip at playhead (S)"/>
            <AppBarButton Icon="Trim" Label="Trim" ToolTipService.ToolTip="Trim clip ends"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Add" Label="Add Clip" ToolTipService.ToolTip="Add media to timeline"/>
            <AppBarButton Label="Transition" ToolTipService.ToolTip="Add transition between clips">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8B5;"/>
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton Icon="ZoomIn" Label="Zoom In" ToolTipService.ToolTip="Zoom timeline in (+)"/>
            <AppBarButton Icon="ZoomOut" Label="Zoom Out" ToolTipService.ToolTip="Zoom timeline out (-)"/>
        </CommandBar>
    </Grid>
</Page>
